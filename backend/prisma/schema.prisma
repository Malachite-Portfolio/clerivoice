generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  LISTENER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum ListenerAvailability {
  ONLINE
  OFFLINE
  BUSY
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  VERIFY_PHONE
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum WalletTransactionType {
  RECHARGE
  REFERRAL_BONUS
  CALL_DEBIT
  CHAT_DEBIT
  REFUND
  ADMIN_CREDIT
  ADMIN_DEBIT
  PROMO_CREDIT
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

enum PaymentProvider {
  MOCK
  RAZORPAY
  STRIPE
}

enum PaymentOrderStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CANCELED
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum RechargePlanStatus {
  ACTIVE
  INACTIVE
}

enum CouponDiscountType {
  FIXED
  PERCENTAGE
}

enum ChatSessionStatus {
  REQUESTED
  ACTIVE
  ENDED
  CANCELLED
  REJECTED
}

enum CallSessionStatus {
  REQUESTED
  RINGING
  ACTIVE
  ENDED
  MISSED
  REJECTED
  CANCELLED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ReferralStatus {
  INVITED
  SIGNED_UP
  QUALIFIED
  REWARDED
  EXPIRED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  MEDIUM
  HIGH
}

enum SessionEndReason {
  USER_ENDED
  LISTENER_ENDED
  INSUFFICIENT_BALANCE
  REJECTED
  MISSED
  CANCELLED
  ERROR
  TIMEOUT
}

model User {
  id              String     @id @default(cuid())
  phone           String     @unique
  email           String?    @unique
  passwordHash    String?
  displayName     String
  role            Role       @default(USER)
  status          UserStatus @default(ACTIVE)
  isPhoneVerified Boolean    @default(false)
  profileImageUrl String?
  blockedReason   String?
  referredById    String?
  referralApplied Boolean    @default(false)
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  referredBy   User?  @relation("ReferrerToUsers", fields: [referredById], references: [id])
  invitedUsers User[] @relation("ReferrerToUsers")

  listenerProfile ListenerProfile?
  wallet          Wallet?
  otpCodes        OtpCode[]
  authSessions    AuthSession[]
  settings        UserSetting?
  referralCode    ReferralCode?
  pushDevices     PushDevice[]

  referralsMade    Referral[] @relation("ReferralInviter")
  referralReceived Referral[] @relation("ReferralReferred")

  walletTransactions  WalletTransaction[]
  paymentOrders       PaymentOrder[]
  paymentTransactions PaymentTransaction[]

  chatSessionsAsUser     ChatSession[] @relation("ChatUser")
  chatSessionsAsListener ChatSession[] @relation("ChatListener")

  callSessionsAsUser     CallSession[] @relation("CallUser")
  callSessionsAsListener CallSession[] @relation("CallListener")

  sentMessages     ChatMessage[] @relation("MessageSender")
  receivedMessages ChatMessage[] @relation("MessageReceiver")

  supportTickets SupportTicket[]

  @@index([role, status])
  @@index([status, createdAt])
}

model ListenerProfile {
  id                String               @id @default(cuid())
  userId            String               @unique
  bio               String?
  rating            Decimal              @default(0) @db.Decimal(4, 2)
  experienceYears   Int                  @default(0)
  languages         String[]
  category          String?
  callRatePerMinute Decimal              @default(15) @db.Decimal(10, 2)
  chatRatePerMinute Decimal              @default(10) @db.Decimal(10, 2)
  availability      ListenerAvailability @default(OFFLINE)
  isEnabled         Boolean              @default(true)
  totalSessions     Int                  @default(0)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([availability, isEnabled])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions WalletTransaction[]

  @@index([updatedAt])
}

model WalletTransaction {
  id               String                  @id @default(cuid())
  userId           String
  walletId         String
  type             WalletTransactionType
  status           WalletTransactionStatus @default(SUCCESS)
  amount           Decimal                 @db.Decimal(14, 2)
  balanceBefore    Decimal                 @db.Decimal(14, 2)
  balanceAfter     Decimal                 @db.Decimal(14, 2)
  relatedSessionId String?
  relatedPaymentId String?
  description      String?
  metadata         Json?
  idempotencyKey   String?                 @unique
  createdAt        DateTime                @default(now())

  user               User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  wallet             Wallet        @relation(fields: [walletId], references: [id], onDelete: Restrict)
  qualifyingReferral Referral?     @relation("ReferralQualifyingTransaction")
  paymentOrder       PaymentOrder? @relation("PaymentOrderWalletTransaction")

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([relatedSessionId])
  @@index([relatedPaymentId])
}

model PaymentOrder {
  id                  String             @id @default(cuid())
  userId              String
  provider            PaymentProvider    @default(MOCK)
  gatewayOrderId      String?            @unique
  amount              Decimal            @db.Decimal(14, 2)
  currency            String             @default("INR")
  status              PaymentOrderStatus @default(PENDING)
  couponCode          String?
  discountAmount      Decimal            @default(0) @db.Decimal(14, 2)
  payableAmount       Decimal            @db.Decimal(14, 2)
  metadata            Json?
  walletTransactionId String?            @unique
  verifiedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user              User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions      PaymentTransaction[]
  walletTransaction WalletTransaction?   @relation("PaymentOrderWalletTransaction", fields: [walletTransactionId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([provider, status])
}

model PaymentTransaction {
  id               String                   @id @default(cuid())
  paymentOrderId   String
  userId           String
  provider         PaymentProvider          @default(MOCK)
  gatewayPaymentId String?
  gatewaySignature String?
  status           PaymentTransactionStatus @default(PENDING)
  amount           Decimal                  @db.Decimal(14, 2)
  method           String?
  metadata         Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  paymentOrder PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Restrict)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([paymentOrderId, status, createdAt])
  @@index([gatewayPaymentId])
}

model RechargePlan {
  id        Int                @id @default(autoincrement())
  amount    Decimal            @db.Decimal(10, 2)
  talktime  Decimal            @db.Decimal(10, 2)
  label     String?
  status    RechargePlanStatus @default(ACTIVE)
  sortOrder Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([status, sortOrder])
}

model Coupon {
  id            String             @id @default(cuid())
  code          String             @unique
  description   String?
  discountType  CouponDiscountType
  discountValue Decimal            @db.Decimal(10, 2)
  minAmount     Decimal            @db.Decimal(10, 2)
  maxDiscount   Decimal?           @db.Decimal(10, 2)
  isActive      Boolean            @default(true)
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([isActive, expiresAt])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model ReferralRewardRule {
  id               String   @id @default(cuid())
  name             String   @unique
  inviterReward    Decimal  @db.Decimal(10, 2)
  referredReward   Decimal  @db.Decimal(10, 2)
  qualifyingAmount Decimal  @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
}

model Referral {
  id                      String         @id @default(cuid())
  inviterUserId           String
  referredUserId          String         @unique
  referralCode            String
  status                  ReferralStatus @default(INVITED)
  qualifyingTransactionId String?        @unique
  inviterRewardAmount     Decimal        @default(0) @db.Decimal(10, 2)
  referredRewardAmount    Decimal        @default(0) @db.Decimal(10, 2)
  rewardedAt              DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  inviter               User               @relation("ReferralInviter", fields: [inviterUserId], references: [id], onDelete: Restrict)
  referred              User               @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Restrict)
  qualifyingTransaction WalletTransaction? @relation("ReferralQualifyingTransaction", fields: [qualifyingTransactionId], references: [id], onDelete: SetNull)

  @@index([inviterUserId, status])
  @@index([status, createdAt])
}

model ChatSession {
  id            String            @id @default(cuid())
  userId        String
  listenerId    String
  status        ChatSessionStatus @default(REQUESTED)
  requestedAt   DateTime          @default(now())
  startedAt     DateTime?
  endedAt       DateTime?
  billedMinutes Int               @default(0)
  ratePerMinute Decimal           @db.Decimal(10, 2)
  totalAmount   Decimal           @default(0) @db.Decimal(14, 2)
  endReason     SessionEndReason?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user     User          @relation("ChatUser", fields: [userId], references: [id], onDelete: Restrict)
  listener User          @relation("ChatListener", fields: [listenerId], references: [id], onDelete: Restrict)
  messages ChatMessage[]

  @@index([userId, status, createdAt])
  @@index([listenerId, status, createdAt])
}

model ChatMessage {
  id          String        @id @default(cuid())
  sessionId   String
  senderId    String
  receiverId  String
  messageType String        @default("text")
  content     String
  status      MessageStatus @default(SENT)
  readAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  session  ChatSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  sender   User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  receiver User        @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Restrict)

  @@index([sessionId, createdAt])
  @@index([receiverId, status])
}

model CallSession {
  id              String            @id @default(cuid())
  userId          String
  listenerId      String
  status          CallSessionStatus @default(REQUESTED)
  requestedAt     DateTime          @default(now())
  startedAt       DateTime?
  answeredAt      DateTime?
  endedAt         DateTime?
  durationSeconds Int               @default(0)
  billedMinutes   Int               @default(0)
  ratePerMinute   Decimal           @db.Decimal(10, 2)
  totalAmount     Decimal           @default(0) @db.Decimal(14, 2)
  endReason       SessionEndReason?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user     User        @relation("CallUser", fields: [userId], references: [id], onDelete: Restrict)
  listener User        @relation("CallListener", fields: [listenerId], references: [id], onDelete: Restrict)
  events   CallEvent[]

  @@index([userId, status, createdAt])
  @@index([listenerId, status, createdAt])
}

model CallEvent {
  id        String   @id @default(cuid())
  sessionId String
  eventType String
  payload   Json?
  createdAt DateTime @default(now())

  session CallSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@index([sessionId, createdAt])
}

model SupportTicket {
  id         String              @id @default(cuid())
  userId     String
  subject    String
  message    String
  status     SupportTicketStatus @default(OPEN)
  priority   SupportPriority     @default(MEDIUM)
  resolvedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, status, createdAt])
}

model UserSetting {
  id             String   @id @default(cuid())
  userId         String   @unique
  language       String   @default("en")
  allowPush      Boolean  @default(true)
  allowSms       Boolean  @default(true)
  anonymousMode  Boolean  @default(true)
  marketingOptIn Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model AuthSession {
  id               String            @id @default(cuid())
  userId           String
  refreshTokenHash String
  deviceId         String?
  deviceInfo       Json?
  ipAddress        String?
  userAgent        String?
  status           AuthSessionStatus @default(ACTIVE)
  expiresAt        DateTime
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, status, expiresAt])
  @@index([deviceId])
}

model PushDevice {
  id            String   @id @default(cuid())
  userId        String
  expoPushToken String   @unique
  appFlavor     String
  platform      String   @default("android")
  deviceId      String?
  deviceName    String?
  deviceInfo    Json?
  isActive      Boolean  @default(true)
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, appFlavor])
  @@index([lastSeenAt])
}

model OtpCode {
  id         String     @id @default(cuid())
  userId     String?
  phone      String
  codeHash   String
  purpose    OtpPurpose
  status     OtpStatus  @default(PENDING)
  attempts   Int        @default(0)
  expiresAt  DateTime
  verifiedAt DateTime?
  metadata   Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, purpose, status])
  @@index([expiresAt])
}

model AppConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}
